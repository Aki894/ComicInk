<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/eink_background">

    <!-- 图片显示区域（ViewPager 替代方案：自定义 View） -->
    <com.comicink.ui.view.EInkImageView
        android:id="@+id/readerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 页码指示器 - E-ink 优化：不透明背景 -->
    <TextView
        android:id="@+id/tvPageIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@color/eink_background"
        android:padding="8dp"
        android:textColor="@color/eink_text_primary"
        android:textSize="14sp"
        android:text="1 / 1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 顶部信息栏（点击显示/隐藏） -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/eink_background"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvComicTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/eink_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:text="漫画标题" />

        <TextView
            android:id="@+id/tvChapterTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/eink_text_secondary"
            android:textSize="14sp"
            android:text="章节标题" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>