<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/eink_background"
    android:foreground="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/tvSourceName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/eink_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:text="Source Name" />

    <TextView
        android:id="@+id/tvSourceKey"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/eink_text_secondary"
        android:textSize="12sp"
        android:text="key" />

    <TextView
        android:id="@+id/tvSourceVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/eink_text_secondary"
        android:textSize="11sp"
        android:text="v1.0.0" />

</LinearLayout>